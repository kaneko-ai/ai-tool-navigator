---
permalink: /sitemap.xml
eleventyExcludeFromCollections: true
layout: false
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url>
    <loc>https://kaneko-ai.github.io{{ '/' | url }}</loc>
    <changefreq>daily</changefreq>
    <priority>1.0</priority>
  </url>
  <url>
    <loc>https://kaneko-ai.github.io{{ '/articles/' | url }}</loc>
    <changefreq>daily</changefreq>
    <priority>0.9</priority>
  </url>
  <url>
    <loc>https://kaneko-ai.github.io{{ '/tags/' | url }}</loc>
    <changefreq>weekly</changefreq>
    <priority>0.7</priority>
  </url>
  {% for tag in collections.tagList %}
  <url>
    <loc>https://kaneko-ai.github.io{{ ('/tags/' + tag + '/') | url }}</loc>
    <changefreq>weekly</changefreq>
    <priority>0.6</priority>
  </url>
  {% endfor %}
  {% for post in collections.articles %}
  <url>
    <loc>https://kaneko-ai.github.io{{ post.url | url }}</loc>
    <lastmod>{{ post.date.toISOString() }}</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.8</priority>
  </url>
  {% endfor %}
</urlset>
