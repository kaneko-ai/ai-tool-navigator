<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="google-site-verification" content="s5O5ewNj4ezNiNm9OrPmNNzaqHaU2yHeaA-B11Kfp2c" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} | AI Tool Navigator</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="{{ '/assets/css/style.css' | url }}">

  {# --- OGP / Twitter Card / Canonical --- #}
  {% set siteName = "ai-tool-navigator" %}
  {% set siteUrl = "https://kaneko-ai.github.io/ai-tool-navigator" %}
  {% set defaultDesc = "AI関連ツールの比較・解説サイト。AI学習、フリーランス転職、英語学習の実用ガイドをまとめています。" %}
  {% set pageTitle = title or (siteName + " | AIツール比較・解説") %}
  {% set pageDesc = description or defaultDesc %}
  {% set pageUrl = siteUrl + (page.url or "/") %}

  <meta name="description" content="{{ pageDesc }}">
  <link rel="canonical" href="{{ pageUrl }}">

  <meta property="og:type" content="{% if layout == 'post.njk' %}article{% else %}website{% endif %}">
  <meta property="og:site_name" content="{{ siteName }}">
  <meta property="og:title" content="{{ pageTitle }}">
  <meta property="og:description" content="{{ pageDesc }}">
  <meta property="og:url" content="{{ pageUrl }}">
  <meta property="og:locale" content="ja_JP">

  <meta property="og:image" content="{{ ogpImage or 'https://kaneko-ai.github.io/ai-tool-navigator/assets/images/ogp-default.png' }}">

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ pageTitle }}">
  <meta name="twitter:description" content="{{ pageDesc }}">
  <meta name="twitter:image" content="{{ ogpImage or 'https://kaneko-ai.github.io/ai-tool-navigator/assets/images/ogp-default.png' }}">

  {% if noindex %}<meta name="robots" content="noindex,follow">{% endif %}

  <!-- Google Analytics 4 -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-8J2LVW54HE"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag("js", new Date());
    gtag("config", "G-8J2LVW54HE");
  </script>

  <!-- A8.net リンクマネージャー -->
  <script src="//statics.a8.net/a8link/a8linkmgr.js"></script>
  <script>
    a8linkmgr({
      "config_id": "itj6xcWwFeglyMnguTqS"
    });
  </script>
</head>
<body>
  <div class="site-shell">
    <nav class="site-nav">
      <a href="{{ '/' | url }}">ホーム</a>
      <a href="{{ '/articles/' | url }}">記事一覧</a>
      <a href="{{ '/tags/' | url }}">タグ</a>
    </nav>

    <div class="layout">
      <main class="layout__main">
        {{ content | safe }}
      </main>
      {% include "partials/sidebar-ad.njk" %}
    </div>

    <footer class="site-footer">
      <p>
        <a href="{{ '/about/' | url }}">運営者情報</a>
        <a href="{{ '/privacy/' | url }}">プライバシーポリシー</a>
      </p>
      <p>© ai-tool-navigator</p>
    </footer>
  </div>
</body>
</html>
