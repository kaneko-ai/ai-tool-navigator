<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="google-site-verification" content="s5O5ewNj4ezNiNm9OrPmNNzaqHaU2yHeaA-B11Kfp2c" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} | AI Tool Navigator</title>
  {% if description %}<meta name="description" content="{{ description }}">{% endif %}
  {% if noindex %}<meta name="robots" content="noindex, nofollow">{% endif %}
  {% if description %}<meta property="og:description" content="{{ description }}">{% endif %}
  <meta property="og:title" content="{{ title }}">
  <meta property="og:type" content="article">
  <style>
    body {
      background: #0d1117;
      color: #e6edf3;
      font-size: 16px;
      line-height: 1.8;
      max-width: 800px;
      margin: 0 auto;
      padding: 20px;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
    }
    a {
      color: #58a6ff;
      text-decoration: none;
    }
    a:hover {
      text-decoration: underline;
    }
    h1, h2, h3 {
      color: #ffffff;
    }
    code, pre {
      background: #161b22;
      padding: 0.2em 0.5em;
      border-radius: 4px;
    }
    nav {
      border-bottom: 1px solid #30363d;
      padding-bottom: 10px;
      margin-bottom: 20px;
    }
    footer {
      border-top: 1px solid #30363d;
      margin-top: 40px;
      padding-top: 10px;
      font-size: 14px;
      color: #8b949e;
      text-align: center;
    }
    .container {
      max-width: 800px;
      margin: 0 auto;
      padding: 20px;
    }
    .pr-notice {
      background: #1f2937;
      border-left: 3px solid #58a6ff;
      padding: 10px 14px;
      margin: 20px 0;
      font-size: 14px;
      color: #c9d1d9;
      border-radius: 4px;
    }
    .ai-disclosure {
      background: #161b22;
      border: 1px solid #30363d;
      padding: 12px 16px;
      margin-top: 30px;
      font-size: 13px;
      color: #8b949e;
      border-radius: 4px;
    }
  </style>
  <-REPO_DIR = /Users/common/ai-tool-navigator
+REPO_DIR = Google Analytics 4 -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-8J2LVW54HE"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag("js", new Date());
    gtag("config", "G-8J2LVW54HE");
  </script>
</head>
<body>
  <div class="container">
    <nav>
      <a href="{{ '/' | url }}">ホーム</a>
      <a href="{{ '/articles/' | url }}">記事一覧</a>
    </nav>

    {{ content | safe }}

    <footer>
      <p>
        <a href="{{ '/about/' | url }}">運営者情報</a> ・
        <a href="{{ '/privacy/' | url }}">プライバシーポリシー</a>
      </p>
      <p>Powered by Navigator X</p>
    </footer>
  </div>
</body>
</html>
