<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="google-site-verification" content="s5O5ewNj4ezNiNm9OrPmNNzaqHaU2yHeaA-B11Kfp2c" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} | AI Tool Navigator</title>
  {% if description %}<meta name="description" content="{{ description }}">{% endif %}
  {% if noindex %}<meta name="robots" content="noindex, nofollow">{% endif %}
  {% if description %}<meta property="og:description" content="{{ description }}">{% endif %}
  <meta property="og:title" content="{{ title }}">
  <meta property="og:type" content="article">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="{{ '/assets/css/style.css' | url }}">
  <!-- Google Analytics 4 -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-8J2LVW54HE"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag("js", new Date());
    gtag("config", "G-8J2LVW54HE");
  </script>
</head>
<body>
  <div class="container">
    <nav>
      <a href="{{ '/' | url }}">ホーム</a>
      <a href="{{ '/articles/' | url }}">記事一覧</a>
      <a href="{{ '/tags/' | url }}">タグ</a>
    </nav>

    {{ content | safe }}

    <footer>
      <p>
        <a href="{{ '/about/' | url }}">運営者情報</a>
        <a href="{{ '/privacy/' | url }}">プライバシーポリシー</a>
      </p>
      <p>Powered by Navigator X</p>
    </footer>
  </div>
</body>
</html>
