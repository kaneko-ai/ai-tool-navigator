<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="google-site-verification" content="s5O5ewNj4ezNiNm9OrPmNNzaqHaU2yHeaA-B11Kfp2c" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} | AI Tool Navigator</title>
  <style>
    body {
      background: #0d1117;
      color: #e6edf3;
      font-size: 16px;
      line-height: 1.8;
      max-width: 800px;
      margin: 0 auto;
      padding: 20px;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
    }
    a {
      color: #58a6ff;
      text-decoration: none;
    }
    a:hover {
      text-decoration: underline;
    }
    h1, h2, h3 {
      color: #ffffff;
    }
    code, pre {
      background: #161b22;
      padding: 0.2em 0.5em;
      border-radius: 4px;
    }
    nav {
      border-bottom: 1px solid #30363d;
      padding-bottom: 10px;
      margin-bottom: 20px;
    }
    footer {
      border-top: 1px solid #30363d;
      margin-top: 40px;
      padding-top: 10px;
      font-size: 14px;
      color: #8b949e;
      text-align: center;
    }
    .container {
      max-width: 800px;
      margin: 0 auto;
      padding: 20px;
    }
  </style>
</head>
<body>
  <div class="container">
    <nav>
      <a href="{{ '/' | url }}">ホーム</a>
      <a href="{{ '/articles/' | url }}">記事一覧</a>
    </nav>

    {{ content | safe }}

    <footer>
      Powered by Navigator X
    </footer>
  </div>
</body>
</html>
